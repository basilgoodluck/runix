{
  "name": "@basilgoodluck/runix-sdk",
  "version": "0.1.1",
  "description": "Official TypeScript SDK for the Runix machine-to-machine execution engine",
  "keywords": [
    "runix",
    "execution",
    "agent",
    "compute",
    "usdc",
    "arc",
    "sandbox"
  ],
  "homepage": "https://github.com/basilgoodluck/runix/tree/main#readme",
  "bugs": {
    "url": "https://github.com/basilgoodluck/runix/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/basilgoodluck/runix.git#main"
  },
  "license": "MIT",
  "author": "basilgoodluck",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "@types/node": "^20.0.0"
  },
  "module": "dist/index.mjs"
}
