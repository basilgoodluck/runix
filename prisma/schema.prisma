datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model Agent {
  id             String    @id
  apiKey         String    @unique
  walletId       String
  walletAddress  String
  onchainAgentId String?
  txHash         String?
  metadataUri    String
  createdAt      DateTime  @default(now())
  jobs           Job[]
  payments       Payment[]
}

model Job {
  id         String   @id
  agentId    String
  type       String
  status     String
  costUsd    Float?
  durationMs Int
  createdAt  DateTime @default(now())
  agent      Agent    @relation(fields: [agentId], references: [id])
}

model Payment {
  id        String   @id @default(uuid())
  agentId   String
  jobId     String
  txId      String
  amount    String
  createdAt DateTime @default(now())
  agent     Agent    @relation(fields: [agentId], references: [id])
}
