datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id            String         @id @default(uuid())
  email         String         @unique
  name          String
  picture       String         @default("")
  createdAt     DateTime       @default(now())
  agents        Agent[]
  refreshTokens RefreshToken[]
}

model Agent {
  id             String   @id
  apiKey         String   @unique
  walletId       String
  walletAddress  String
  onchainAgentId String?
  txHash         String?
  metadataUri    String
  createdAt      DateTime @default(now())
  userId         String
  user           User     @relation(fields: [userId], references: [id])
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Job {
  id         String   @id
  agentId    String
  type       String
  status     String
  costUsd    Float?
  durationMs Int
  createdAt  DateTime @default(now())
}

model Payment {
  id        String   @id @default(uuid())
  agentId   String
  jobId     String
  txId      String
  amount    String
  createdAt DateTime @default(now())
}