generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String
  apiKey    String   @unique
  createdAt DateTime @default(now())
}

model Agent {
  id             String   @id
  apiKey         String   @unique
  walletId       String
  walletAddress  String
  onchainAgentId String?
  txHash         String?
  metadataUri    String
  createdAt      DateTime @default(now())
}

model Job {
  id        String   @id
  agentId   String
  type      String
  status    String
  costUsd   Float?
  durationMs Int
  createdAt DateTime @default(now())
}

model Payment {
  id        String   @id @default(uuid())
  agentId   String
  jobId     String
  txId      String
  amount    String
  createdAt DateTime @default(now())
}